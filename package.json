    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-rate-limit": "^5.1.3",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
